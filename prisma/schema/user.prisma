model User {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String

    role   UserRole   @default(TENANT)
    status UserStatus @default(ACTIVE)

    phone        String?
    profileImage String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    properties     Property[]
    rentalRequests RentalRequest[]
    payments       Payment[]
    reviews        Review[]

    @@map("users")
}
