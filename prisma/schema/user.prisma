model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         UserRole   @default(TENANT)
  status       UserStatus @default(ACTIVE)
  phone        String?
  profileImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments       Payment[]
  properties     Property[]
  rentalRequests RentalRequest[]
  reviews        Review[]

  @@map("users")
}
