model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String
  tenantId   String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id])
  tenant     User     @relation(fields: [tenantId], references: [id])

  @@map("reviews")
}
